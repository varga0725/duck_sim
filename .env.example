# ==============================================================================
# Duck Simulator & Gemini Live / Hermes Agent Configuration Template
# Copy this file to .env (or ~/.hermes/.env) and populate with your API keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# Google Gemini Multimodal Live API
# ------------------------------------------------------------------------------
# Required for bidirectional real-time audio and video streaming.
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative/Fallback variable (either GEMINI_API_KEY or GOOGLE_API_KEY is fine)
GOOGLE_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# Hermes Developer Agent (Optional)
# ------------------------------------------------------------------------------
# If running Hermes in HTTP server mode, specify the backend endpoint here.
HERMES_API_URL=http://127.0.0.1:8000

# ------------------------------------------------------------------------------
# Simulator Mode
# ------------------------------------------------------------------------------
# Mode of the MuJoCo simulator:
# - 'real': Full physical room simulation, ONNX locomotion, active tracking.
# - 'stub': High-performance mocked endpoints for testing/CI.
DUCK_SIM_MODE=real
