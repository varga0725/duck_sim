    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        
        <texture type="2d" name="tex_wood" file="assets/wood.png"/>
        <texture type="2d" name="tex_brick" file="assets/brick.png"/>
        <texture type="2d" name="tex_ball" file="assets/ball.png"/>
        
        <material name="mat_wood" texture="tex_wood" texuniform="true" texrepeat="2 2" reflectance="0.1"/>
        <material name="mat_brick" texture="tex_brick" texuniform="true" texrepeat="5 2"/>
        <material name="mat_ball" texture="tex_ball"/>
    </asset>

    <worldbody>
        <!-- Lighting -->
        <light pos="0 0 3.5" dir="0 0 -1" directional="true"/>
        
        <!-- Floor -->
        <body name="floor">
            <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="mat_wood" contype="1"
                conaffinity="0" priority="1" friction="0.6" condim="3"/>
        </body>
        
        <!-- Walls -->
        <body name="wall_front" pos="4 0 1">
            <geom type="box" size="0.1 4 1" material="mat_brick" contype="1" conaffinity="1"/>
        </body>
        <body name="wall_left" pos="0 4 1">
            <geom type="box" size="4 0.1 1" material="mat_brick" contype="1" conaffinity="1"/>
        </body>
        <body name="wall_right" pos="0 -4 1">
            <geom type="box" size="4 0.1 1" material="mat_brick" contype="1" conaffinity="1"/>
        </body>
        <body name="wall_back" pos="-4 0 1">
            <geom type="box" size="0.1 4 1" material="mat_brick" contype="1" conaffinity="1"/>
        </body>
        
        <!-- Dining Table (static) -->
        <body name="table" pos="2.0 -0.5 0">
            <!-- Table top -->
            <geom type="box" pos="0 0 0.6" size="0.5 0.4 0.02" material="mat_wood" contype="1" conaffinity="1"/>
            <!-- Legs -->
            <geom type="box" pos="-0.4 -0.3 0.3" size="0.02 0.02 0.3" material="mat_wood" contype="1" conaffinity="1"/>
            <geom type="box" pos="0.4 -0.3 0.3" size="0.02 0.02 0.3" material="mat_wood" contype="1" conaffinity="1"/>
            <geom type="box" pos="-0.4 0.3 0.3" size="0.02 0.02 0.3" material="mat_wood" contype="1" conaffinity="1"/>
            <geom type="box" pos="0.4 0.3 0.3" size="0.02 0.02 0.3" material="mat_wood" contype="1" conaffinity="1"/>
        </body>
        
        <!-- Chair (static) -->
        <body name="chair" pos="1.2 -0.5 0" euler="0 0 0">
            <!-- Seat -->
            <geom type="box" pos="0 0 0.35" size="0.2 0.2 0.02" material="mat_wood" contype="1" conaffinity="1"/>
            <!-- Backrest -->
            <geom type="box" pos="-0.18 0 0.55" size="0.02 0.2 0.2" material="mat_wood" contype="1" conaffinity="1"/>
            <!-- Legs -->
            <geom type="box" pos="-0.18 -0.18 0.175" size="0.02 0.02 0.175" material="mat_wood" contype="1" conaffinity="1"/>
            <geom type="box" pos="0.18 -0.18 0.175" size="0.02 0.02 0.175" material="mat_wood" contype="1" conaffinity="1"/>
            <geom type="box" pos="-0.18 0.18 0.175" size="0.02 0.02 0.175" material="mat_wood" contype="1" conaffinity="1"/>
            <geom type="box" pos="0.18 0.18 0.175" size="0.02 0.02 0.175" material="mat_wood" contype="1" conaffinity="1"/>
        </body>
        
        <!-- Sports Ball (freejoint) -->
        <body name="sports_ball" pos="1.0 0.5 0.1">
            <freejoint/>
            <geom type="sphere" size="0.1" material="mat_ball" mass="0.4" contype="1" conaffinity="1"/>
        </body>
        
    </worldbody>

